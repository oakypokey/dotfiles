{{- $opencodeProviderMetal := get . "opencode_provider_metal" | default false -}}
{{- $opencodeProviderOllama := get . "opencode_provider_ollama" | default false -}}
{{- $opencodeProviderOpenai := get . "opencode_provider_openai" | default false -}}
{{- $opencodeOllamaHost := get . "opencode_ollama_host" | default "" -}}
{{- $opencodeMetalHost := get . "opencode_metal_host" | default "" -}}
{{- $mcpServers := get . "mcp_servers" | default (get . "opencode_mcp_servers") | default (list) -}}
{{- define "openaiCompatibleProvider" }}
    "{{ .id }}": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "{{ .name }}",
      "options": {
        "baseURL": "{{ .baseURL }}"
      },
      "models": {{ .models | toPrettyJson | trimSuffix "\n" | replace "\n" "\n      " }}
    }
{{- end -}}
{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "small_model": "metal/apple-foundationmodel",
  "disabled_providers": [
    "github-copilot",
    "opencode"
  ],
  "enabled_providers": [
{{- $enabledProviderComma := false -}}
{{- if $opencodeProviderOllama }}
    "ollama"
{{- $enabledProviderComma = true -}}
{{- end }}
{{- if $opencodeProviderMetal }}{{ if $enabledProviderComma }},{{ end }}
    "metal"
{{- $enabledProviderComma = true -}}
{{- end }}
{{- if $opencodeProviderOpenai }}{{ if $enabledProviderComma }},{{ end }}
    "openai"
{{- end }}
  ],
  "agent": {{ if $opencodeProviderMetal }}{
    "lean": {
      "mode": "subagent",
      "description": "Use to generate short snippets",
      "model": "metal/apple-foundationmodel",
      "prompt": "You are a concise assistant. Answer directly.",
      "permission": {
        "*": "deny"
      }
    }
  }{{ else }}{}{{ end }},
  "provider": {
{{- $providerComma := false -}}
{{- if $opencodeProviderOllama }}
{{- $models := dict "gemma4:e4b" (dict "name" "Gemma 4 [e4b]" "limit" (dict "context" 131072 "output" 2048)) -}}
{{- template "openaiCompatibleProvider" (dict "id" "ollama" "name" "Ollama" "baseURL" $opencodeOllamaHost "models" $models) }}
{{- $providerComma = true -}}
{{- end }}
{{- if $opencodeProviderMetal }}{{ if $providerComma }},{{ end }}
{{- $models := dict "apple-foundationmodel" (dict "name" "Apple Foundational Model" "limit" (dict "context" 4096 "output" 1024)) -}}
{{- template "openaiCompatibleProvider" (dict "id" "metal" "name" "Metal" "baseURL" $opencodeMetalHost "models" $models) }}
{{- $providerComma = true -}}
{{- end }}
{{- if $opencodeProviderOpenai }}{{ if $providerComma }},{{ end }}
    "openai": {
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": [
          "reasoning.encrypted_content"
        ],
        "store": false
      },
      "models": {
        "gpt-5.2": {
          "name": "GPT 5.2 (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.2-codex": {
          "name": "GPT 5.2 Codex (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.1-codex-max": {
          "name": "GPT 5.1 Codex Max (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.1-codex": {
          "name": "GPT 5.1 Codex (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.1-codex-mini": {
          "name": "GPT 5.1 Codex Mini (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.1": {
          "name": "GPT 5.1 (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "high"
            }
          }
        }
      }
    }
{{- end }}
  },
  "mcp": {
{{- $mcpComma := false -}}
{{- if has "chrome-devtools" $mcpServers }}
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    }
{{- $mcpComma = true -}}
{{- end }}
{{- if has "gitea" $mcpServers }}{{ if $mcpComma }},{{ end }}
    "gitea": {
      "type": "local",
      "command": [
        "go",
        "run",
        "gitea.com/gitea/gitea-mcp@latest",
        "-t",
        "stdio"
      ]
    }
{{- $mcpComma = true -}}
{{- end }}
{{- if has "context7" $mcpServers }}{{ if $mcpComma }},{{ end }}
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
{{- end }}
  },
  "plugin": [
    "opencode-beads",
    "opencode-vibeguard",
    "@mohak34/opencode-notifier@latest",
    "opencode-conductor-plugin",
    "opencode-openai-codex-auth",
    "@tarquinen/opencode-dcp@latest"
  ],
  "permission": {
    "external_directory": {
      "*": "ask",
      "$HOME/.config/agents/rules/**": "allow",
      "$HOME/.config/opencode/rules/**": "allow",
      "/tmp/**": "allow",
      "/var/tmp/**": "allow",
      "/private/tmp/**": "allow",
      "/private/var/tmp/**": "allow"
    }
  },
  "lsp": {}
}
