{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "small_model": "dawggiehaus-metal/apple-foundationmodel",
  "disabled_providers": [
    "github-copilot",
    "opencode"
  ],
  "agent": {
    "lean": {
      "mode": "subagent",
      "description": "Use to generate short snippets",
      "model": "dawggiehaus-metal/apple-foundationmodel",
      "prompt": "You are a concise assistant. Answer directly.",
      "permission": {
        "*": "deny"
      }
    }
  },
  "provider": {
    "dawggiehaus-ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (Dawggiehaus)",
      "options": {
        "baseURL": "http://{{ .opencode_host }}:11434/v1"
      },
      "models": {
        "gemma4:e4b": {
          "name": "Gemma 4 [e4b]",
          "limit": {
            "context": 131072,
            "output": 2048
          }
        }
      }
    },
    "dawggiehaus-metal": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Metal (Dawggiehaus)",
      "options": {
        "baseURL": "http://{{ .opencode_host }}:11435/v1"
      },
      "models": {
        "apple-foundationmodel": {
          "name": "Apple Foundational Model",
          "limit": {
            "context": 4096,
            "output": 1024
          }
        }
      }
    },
    "openai": {
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": [
          "reasoning.encrypted_content"
        ],
        "store": false
      },
      "models": {
        "gpt-5.2": {
          "name": "GPT 5.2 (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.2-codex": {
          "name": "GPT 5.2 Codex (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.1-codex-max": {
          "name": "GPT 5.1 Codex Max (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
