  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "gitea": {
      "type": "local",
      "command": [
        "go",
        "run",
        "gitea.com/gitea/gitea-mcp@latest",
        "-t",
        "stdio"
      ]
    }
  },
  "plugin": [
    "opencode-beads",
    "opencode-vibeguard",
    "@mohak34/opencode-notifier@latest",
    "opencode-conductor-plugin",
    "opencode-openai-codex-auth",
    "@tarquinen/opencode-dcp@latest"
  ]
}
