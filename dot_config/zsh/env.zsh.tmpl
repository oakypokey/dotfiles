{{- $homeDir := printf "/Users/%s" .chezmoi.username }}
{{- $localBin := get . "local_bin" | default (printf "%s/.local/bin" $homeDir) }}
{{- $userBin := get . "user_bin" | default (printf "%s/Bin" $homeDir) }}
# Added by ForgeCode installer
export PATH="{{ $localBin }}:$PATH"
export PATH="$PATH:{{ $userBin }}"
export PATH="$PATH:{{ $userBin }}/scripts"
export PATH="$PATH:{{ $localBin }}:/usr/local/bin:$HOME/.dotnet/tools"

export EDITOR="nvim"

AUTO_NOTIFY_IGNORE+=("docker" "cde")
