for file in \
  "$HOME/.config/zsh/env.zsh" \
  "$HOME/.config/zsh/secrets.zsh" \
  "$HOME/.config/zsh/homebrew.zsh" \
  "$HOME/.config/zsh/zinit.zsh" \
  "$HOME/.config/zsh/oh-my-posh.zsh" \
  "$HOME/.config/zsh/history.zsh" \
  "$HOME/.config/zsh/completion.zsh" \
  "$HOME/.config/zsh/keybindings.zsh" \
  "$HOME/.config/zsh/aliases.zsh" \
  "$HOME/.config/zsh/functions.zsh" \
  "$HOME/.config/zsh/fzf.zsh" \
  "$HOME/.config/zsh/zoxide.zsh"
do
  [[ -r "$file" ]] && source "$file"
done
