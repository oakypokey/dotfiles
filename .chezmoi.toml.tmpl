{{- $email := promptStringOnce . "email" "Email address" -}}
{{- $giteaAccessTokenWanted := promptBoolOnce . "gitea_access_token_available" "Configure Gitea access token" false -}}
{{- $giteaAccessTokenInKeychain := and $giteaAccessTokenWanted (exec "security" "find-generic-password" "-s" "GITEA_ACCESS_TOKEN" "-a" .chezmoi.username) -}}
{{- $giteaAccessToken := "" -}}
{{- if and $giteaAccessTokenWanted (not $giteaAccessTokenInKeychain) -}}
{{- $giteaAccessToken = promptStringOnce . "gitea_access_token" "Gitea access token" -}}
{{- if $giteaAccessToken -}}
{{- exec "security" "add-generic-password" "-U" "-s" "GITEA_ACCESS_TOKEN" "-a" .chezmoi.username "-w" $giteaAccessToken -}}
{{- end -}}
{{- end -}}
{{- $giteaHost := promptStringOnce . "gitea_host" "Gitea host URL" "https://cryptic.spren" -}}
{{- $opencodeProviderOllama := promptBoolOnce . "opencode_provider_ollama" "Include OpenCode Ollama provider" true -}}
{{- $opencodeProviderMetal := promptBoolOnce . "opencode_provider_metal" "Include OpenCode Metal provider" true -}}
{{- $opencodeProviderOpenai := promptBoolOnce . "opencode_provider_openai" "Include OpenCode OpenAI provider" true -}}
{{- $opencodeOllamaHostDefault := "http://localhost:11434/v1" -}}
{{- $legacyOpencodeHost := get . "opencode_host" -}}
{{- if $legacyOpencodeHost -}}
{{- $opencodeOllamaHostDefault = $legacyOpencodeHost -}}
{{- end -}}
{{- $opencodeOllamaHost := "" -}}
{{- if $opencodeProviderOllama -}}
{{- $opencodeOllamaHost = promptStringOnce . "opencode_ollama_host" "OpenCode Ollama base URL" $opencodeOllamaHostDefault -}}
{{- end -}}
{{- $opencodeMetalHost := "" -}}
{{- if $opencodeProviderMetal -}}
{{- $opencodeMetalHost = promptStringOnce . "opencode_metal_host" "OpenCode Metal base URL" "http://localhost:11435/v1" -}}
{{- end -}}
{{- $mcpChoices := list "chrome-devtools" "gitea" "context7" -}}
{{- $mcpServers := promptMultichoiceOnce . "mcp_servers" "MCP servers to include" $mcpChoices (list "chrome-devtools" "gitea") -}}
{{- $claudeProvider := promptChoiceOnce . "claude_provider" "Claude Code provider" (list "default" "codex") "codex" -}}
{{- $name := promptStringOnce . "name" "Name" -}}
{{- $homeDir := printf "/Users/%s" .chezmoi.username -}}

[update]
    command = "zsh"
    args = [{{ printf "%s/.config/chezmoi/update.zsh" $homeDir | quote }}]

[data]
    email = {{ $email | quote }}
    claude_provider = {{ $claudeProvider | quote }}
    gitea_access_token_available = {{ or $giteaAccessTokenInKeychain (ne $giteaAccessToken "") }}
    gitea_host = {{ $giteaHost | quote }}
    local_bin = {{ printf "%s/.local/bin" $homeDir | quote }}
    name = {{ $name | quote }}
    mcp_servers = {{ $mcpServers | toToml }}
    opencode_metal_host = {{ $opencodeMetalHost | quote }}
    opencode_ollama_host = {{ $opencodeOllamaHost | quote }}
    opencode_provider_metal = {{ $opencodeProviderMetal }}
    opencode_provider_ollama = {{ $opencodeProviderOllama }}
    opencode_provider_openai = {{ $opencodeProviderOpenai }}
    user_bin = {{ printf "%s/Bin" $homeDir | quote }}
